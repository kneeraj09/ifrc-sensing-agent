# Copy this file to .env and fill in your values.
# On Railway: add these as environment variables in the service settings (not as a file).

# Required — Anthropic API key for signal extraction
ANTHROPIC_API_KEY=sk-ant-...

# Optional — ACLED conflict event data (free for humanitarian orgs)
# Register at: https://acleddata.com/register/
ACLED_EMAIL=
ACLED_PASSWORD=

# Optional — Email (IMAP) for field sitreps
# For Gmail: enable IMAP + use an App Password (not your account password)
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_USER=your@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FOLDER=IFRC

# Optional — WhatsApp via Twilio
# Sign up at twilio.com, enable the WhatsApp sandbox, set webhook to /webhook/whatsapp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Optional — Telegram channel monitoring
# Get API_ID and API_HASH from: https://my.telegram.org → API development tools
# Then run: python telegram_setup.py  to generate your session string
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=
# Comma-separated list of public channel usernames to monitor (no @ prefix)
TELEGRAM_CHANNELS=OCHANews,UNHumanitarian,ReliefWeb

# Optional — override default SQLite database path
# On Railway: set this to /data/sensing_agent.db and attach a volume at /data
# SENSING_DB=/data/sensing_agent.db
